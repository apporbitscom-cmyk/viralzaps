# Razorpay (get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_key_secret

# Optional: for subscription flow, create plans in Razorpay Dashboard → Subscriptions → Plans
# RAZORPAY_PLAN_STARTER=plan_xxxx
# RAZORPAY_PLAN_PROFESSIONAL=plan_xxxx
# RAZORPAY_PLAN_ULTIMATE=plan_xxxx

# Server
PORT=4000
RAZORPAY_CURRENCY=USD

# Google Sheets — payment log (pick ONE method)
#
# A) Apps Script webhook (no service account key — use if org blocks iam.disableServiceAccountKeyCreation)
# GOOGLE_APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
# GOOGLE_APPS_SCRIPT_WEBHOOK_SECRET=your_script_property_WEBHOOK_SECRET_same_value
# GOOGLE_SHEET_TAB=Sheet1
#
# B) Service account JSON (share sheet with client_email as Editor)
# GOOGLE_SHEET_ID=1DvuVVXrK_pIgflAWImM497l0Pwe_h-EJm20neNZv0PM
# GOOGLE_SHEET_TAB=Sheet1
# GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json

# Gemini (Trending Topics)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash
